# Copy this to .env.local for local development
# NEVER commit .env.local — it is in .gitignore
# Run: git rm --cached .env.local  if it was accidentally tracked

# ── Supabase ─────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key                       # safe to be public (used client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key       # server-side only — NEVER expose to browser

# ── Stripe ───────────────────────────────────────────────────
# Developers → API keys
STRIPE_SECRET_KEY=sk_live_...                          # use sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...                        # Stripe → Webhooks → signing secret

# ── App ──────────────────────────────────────────────────────
APP_URL=https://hiper-studio.au                        # used for Stripe redirect URLs and invite links
                                                       # use http://localhost:3000 for local dev

# ── Notes ────────────────────────────────────────────────────
# VERCEL_OIDC_TOKEN is injected automatically by the Vercel CLI at runtime.
# Do NOT set it here manually — it rotates on each session.
# If you see it in this file, it was generated by `vercel dev` and should be removed.
