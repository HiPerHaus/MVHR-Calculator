# Copy this to .env.local for local development (never commit .env.local)

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose to browser

# Stripe — Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                   # from Stripe → Webhooks → signing secret

# App
APP_URL=https://your-app.vercel.app               # used for Stripe redirect URLs
